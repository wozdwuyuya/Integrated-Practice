# ===========================================
# 1. 绝对机密文件（防止 API Key 泄露）
# ===========================================
.env
.env.*
*.key
*.pem
secrets/
config.local.*

# ===========================================
# 2. 海思 SDK 与 C/C++ 编译产物（防止仓库体积爆炸）
# ===========================================
out/
build/
dist/
*.o
*.obj
*.bin
*.elf
*.map
*.hex
.ninja*
*.zip
小熊派3863开发参考源码/HiSpark_Toolchain/

# ===========================================
# 3. Python 环境与脚本缓存
# ===========================================
__pycache__/
**/__pycache__/
*.py[cod]
.venv/
venv/
node_modules/

# ===========================================
# 4. 数据与工具文件
# ===========================================
*.csv
*.log
*.exe
*.zip
*.7z

# ===========================================
# 5. IDE 与系统缓存
# ===========================================
.vscode/
.idea/
.DS_Store
Thumbs.db

# ===========================================
